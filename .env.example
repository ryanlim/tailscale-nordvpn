INSTANCE_NAME=us_sfo
# Each running instance must use a unique subnet to avoid Docker network collisions.
IP_SUBNET="10.1.3.0/24"
IP_TAILSCALE="10.1.3.2"
IP_NORDVPN="10.1.3.3"
TAILSCALE_UP_LOGIN_SERVER=
# Optional: pre-auth key for headless Tailscale login. Leave blank to log in manually.
TAILSCALE_AUTHKEY=
# MTU for eth0 inside the Tailscale container. 1385 is the tuned default.
TAILSCALE_ETH_MTU=1385
NORDVPN_TOKEN=
NORDVPN_ENDPOINT=San_Francisco
# Final intended operating mode: NORDLYNX / UDP
NORDVPN_TECHNOLOGY=NORDLYNX
NORDVPN_OPENVPN_PROTOCOL=udp
# Optional: hours between automatic NordVPN reconnects. Leave blank to use the default (1 hour).
NORDVPN_RECONNECT_AFTER_HOURS=
